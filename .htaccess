# 1. Stop cPanel from secretly appending index.php to the root URL
DirectoryIndex disabled

RewriteEngine On

# 2. Tell Next.js the connection is secure
RequestHeader set X-Forwarded-Proto "https"
RequestHeader set X-Forwarded-Port "443"

# 3. Pass the exact requested URL directly to the PM2 app
RewriteRule ^(.*)$ http://127.0.0.1:3005%{REQUEST_URI} [P,L]